{
	"env": {
		"browser": true,
		"es6": true,
		"node": true,
		"commonjs": true
	},
	"extends": [
		"eslint:recommended"
	],
	"globals": {
		"Atomics": "readonly",
		"SharedArrayBuffer": "readonly"
	},
	"parserOptions": {
		"parser": "babel-eslint",
		"ecmaVersion": 2018,
		"sourceType": "module",
		"allowImportExportEverywhere": true
	},
	"plugins": [
		"import",
		"promise",
		"standard"
	],
	"rules": {
		"indent": [
			"error",
			"tab"
		],
		"no-trailing-spaces": [
			2,
			{
				"skipBlankLines": true
			}
		],
		"quotes": [
			2,
			"single",
			{
				"avoidEscape": true
			}
		],
		"semi": [
			2,
			"never"
		]
	},
	"overrides": [
		{
			"rules": {
				"indent": "off"
			}
		}
	]
}