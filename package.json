{
    "name": "berkytt",
    "version": "1.0.0",
    "description": "",
    "main": "./site/templates/assets/main.js",
    "scripts": {
        "watch": "parcel watch ./scripts/main.js --no-hmr --out-dir site/templates/assets/",
        "build": "parcel build ./scripts/main.js --no-source-maps --out-dir site/templates/assets/",
        "browser-sync": "browser-sync start --proxy 'https://berkytt.test' --files 'site/**/*.php' 'site/templates/assets/*.*' 'site/modules/**/*.module' --no-notify"
    },
    "author": "Евгений Буря",
    "license": "MIT",
    "devDependencies": {
        "@babel/core": "^7.14.0",
        "@babel/preset-env": "^7.14.1",
        "babel-cli": "^6.26.0",
        "babel-eslint": "^10.1.0",
        "cssnano": "^7.0.6",
        "eslint": "^6.8.0",
        "eslint-plugin-import": "^2.22.0",
        "eslint-plugin-promise": "^4.2.1",
        "eslint-plugin-standard": "^4.0.1",
        "parcel-bundler": "^1.12.5",
        "sass": "^1.32.8"
    },
    "dependencies": {
        "uikit": "^3.6.16"
    }
}
